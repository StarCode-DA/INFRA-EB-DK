# -------------------------------------------------------------------------
# BASE DE DATOS PostgreSQL
# -------------------------------------------------------------------------
POSTGRES_DB=eclipsebar_db
POSTGRES_USER=eb_user
POSTGRES_PASSWORD=eb_pass
POSTGRES_PORT=5437

# -------------------------------------------------------------------------
# SEGURIDAD - Microservicios
# -------------------------------------------------------------------------
SECRET_KEY=super-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -------------------------------------------------------------------------
# CONFIGURACIÓN DE SERVICIOS
# -------------------------------------------------------------------------
# API Gateway
API_GATEWAY_PORT=8080

# Frontend
FRONTEND_PORT=3000

# Microservicios (puertos externos)
MS_AUTH_PORT=8001
MS_USER_PORT=8002
MS_PRODUCT_PORT=8003
MS_INVENTORY_PORT=8004

# -------------------------------------------------------------------------
# DOCKER HUB
# -------------------------------------------------------------------------
DOCKER_REGISTRY=eclipsebar
DOCKER_TAG=latest

# -------------------------------------------------------------------------
# MODO DE DESARROLLO/PRODUCCIÓN
# -------------------------------------------------------------------------
DEBUG=False
ENVIRONMENT=production

